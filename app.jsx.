  { code: "cs", name: "Čeština", voice: "cs-CZ" },
  { code: "ro", name: "Română", voice: "ro-RO" },
  { code: "hu", name: "Magyar", voice: "hu-HU" },
  { code: "el", name: "Ελληνικά", voice: "el-GR" },
  { code: "he", name: "עברית", voice: "he-IL" },
  { code: "fa", name: "فارسی", voice: "fa-IR" },
];

const css = `
